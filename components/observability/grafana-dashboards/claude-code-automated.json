          "instant": true,
          "format": "table",
          "range": false
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (\"session.id\", \"run.role\", \"run.task\", \"run.user\") (max_over_time({__name__=\"claude_code.token.usage_tokens_total\", \"run.mode\"=\"automated\", \"run.user\"=~\"$auser\", \"run.role\"=~\"$role\", \"run.task\"=~\"$task\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\"}[$__range])) and on (\"session.id\") topk(25, sum by (\"session.id\") (max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"run.mode\"=\"automated\", \"run.user\"=~\"$auser\", \"run.role\"=~\"$role\", \"run.task\"=~\"$task\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\"}[$__range])))",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "session.id": "Session",
              "run.role": "Role",
