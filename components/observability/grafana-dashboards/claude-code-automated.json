          "expr": "sum(max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"run.mode\"=\"automated\", \"run.user\"=~\"$auser\", \"run.role\"=~\"$role\", \"run.task\"=~\"$task\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\", \"session.id\"=~\"$session\"}[$__range])) / (count(count by (\"session.id\") (max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"run.mode\"=\"automated\", \"run.user\"=~\"$auser\", \"run.role\"=~\"$role\", \"run.task\"=~\"$task\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\", \"session.id\"=~\"$session\"}[$__range]))) > 0)"
