      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      }
