{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Multi-session workflow runs tagged with wf.id. Per-workflow and per-step cost, tokens, and reliability. Populates once workflow sessions set OTEL_RESOURCE_ATTRIBUTES (run.mode=workflow,wf.id=\u2026,wf.step=\u2026). See CLAUDE-CODE-OTEL.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/claude-code-usage",
      "icon": "dashboard"
    },
    {
      "title": "Automated",
      "type": "link",
      "url": "/d/claude-code-automated",
      "icon": "dashboard"
    },
    {
      "title": "Workflows",
      "type": "link",
      "url": "/d/claude-code-workflows",
      "icon": "dashboard"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Populating this dashboard",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "This view shows **workflow** runs \u2014 scripts that invoke Claude across multiple sessions, tagged with a workflow id. It fills in once each session in a workflow sets `OTEL_RESOURCE_ATTRIBUTES` with:\n\n```\nrun.mode=workflow,wf.id=<wf_\u2026>,wf.step=<plan|implement|review|\u2026>,run.user=<owner>,run.env=<env>\n```\n\nUse a stable `wf.id` for all sessions in one workflow run, and `wf.step` to mark the stage. See `components/observability/grafana-dashboards/CLAUDE-CODE-OTEL.md`."
      }
    },
    {
      "type": "row",
      "id": 2,
      "title": "Headline (workflows)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Workflow cost",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"wf.id\"=~\"$wf\", \"wf.step\"=~\"$step\", \"run.user\"=~\"$wuser\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\", \"session.id\"=~\"$session\"}[$__range]))",
          "legendFormat": "USD"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 25
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(max_over_time({__name__=\"claude_code.token.usage_tokens_total\", \"wf.id\"=~\"$wf\", \"wf.step\"=~\"$step\", \"run.user\"=~\"$wuser\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\", \"session.id\"=~\"$session\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Workflows",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 5
