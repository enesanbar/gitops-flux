          "range": false
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (\"wf.id\", \"run.user\") (max_over_time({__name__=\"claude_code.token.usage_tokens_total\", \"wf.id\"=~\"$wf\", \"wf.step\"=~\"$step\", \"run.user\"=~\"$wuser\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\"}[$__range])) and on (\"wf.id\") topk(20, sum by (\"wf.id\") (max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"wf.id\"=~\"$wf\", \"wf.step\"=~\"$step\", \"run.user\"=~\"$wuser\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\"}[$__range])))",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "wf.id": "Workflow",
              "run.user": "User",
              "Value #A": "Cost ($)",
              "Value #B": "Tokens"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost ($)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "Cost ($)",
            "desc": true
          }
        ]
      }
