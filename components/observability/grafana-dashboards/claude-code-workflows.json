      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(count by (\"wf.id\") (max_over_time({__name__=\"claude_code.cost.usage_USD_total\", \"wf.id\"=~\"$wf\", \"wf.step\"=~\"$step\", \"run.user\"=~\"$wuser\", model=~\"$model\", effort=~\"$effort\", \"team.id\"=~\"$team\", \"run.env\"=~\"$env\", \"session.id\"=~\"$session\"}[$__range]))) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "description": "Distinct wf.id values in range."
    },
